# Application Configuration
# Copy this file to .env.local and adjust values for your environment

# WebSocket Signaling Server (set to your machine's LAN IP before running)
VITE_SIGNALING_URL=ws://localhost:8765

# API Configuration
VITE_API_URL=http://localhost:3000

# Logging
VITE_ENABLE_LOGGING=true

# File Upload Limits (in MB)
VITE_MAX_FILE_SIZE=100

# Export Settings
VITE_MAX_EXPORT_RETRIES=3
